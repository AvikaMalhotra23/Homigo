<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Homigo" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/sky_blue</item>
        <item name="colorPrimaryVariant">@color/sky_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/mint</item>
        <item name="colorSecondaryVariant">@color/mint</item>
        <item name="colorOnSecondary">@color/graphite</item>
        
        <!-- Status bar color & window background & navigation bar. -->
        <item name="android:statusBarColor">@color/sky_blue</item>
        <item name="android:navigationBarColor">@color/ice_white</item>
        <item name="android:windowBackground">@color/ice_white</item>
    </style>
</resources>